# ============================================================================
# Vedge Landing Site (Next.js) — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# ============================================================================

# The Vedge frontend app URL — where login/register live.
# In production: https://app.vedge.health
NEXT_PUBLIC_APP_URL=http://localhost:5177

# The Vedge backend API URL — used by ISR to fetch plan catalog etc.
# In production: https://api.vedge.health
NEXT_PUBLIC_API_URL=http://localhost:8050
